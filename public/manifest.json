  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.nabhahealth.app",
      "id": "com.nabhahealth.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/nabha-health/id123456789"
    }
  ],
  "display_override": [
    "window-controls-overlay",
    "minimal-ui",
    "standalone",
    "browser"
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+nabhahealth",
      "url": "/handle?protocol=%s"
    },
    {
      "protocol": "web+telemedicine",
      "url": "/consultation?protocol=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/records/import",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"],
        "application/pdf": [".pdf"]
      }
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "image/*",
            "application/pdf",
            "text/plain"
          ]
        }
      ]
    }
  },
  "handle_links": "preferred",
  "capture_links": "existing-client-navigate",
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "permissions_policy": {
    "camera": ["self"],
    "microphone": ["self"],
    "geolocation": ["self"],
    "notifications": ["self"]
  },
  "note_taking": {
    "new_note_url": "/notes/new"
  },
  "widgets": [
    {
      "name": "Quick Stats",
      "description": "View your health statistics at a glance",
      "tag": "health-stats",
      "template": "health-stats-template",
      "ms_ac_template": "health-stats-adaptive-card.json",
      "data": "/api/widget/stats",
      "type": "application/json",
      "screenshots": [
        {
          "src": "widget-stats.png",
          "sizes": "256x256",
          "label": "Health statistics widget showing doctor availability"
        }
      ],
      "icons": [
        {
          "src": "widget-icon-stats.png",
          "sizes": "64x64",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Medicine Reminders",
      "description": "Track your medicine schedule",
      "tag": "medicine-reminder",
      "template": "medicine-reminder-template",
      "ms_ac_template": "medicine-reminder-adaptive-card.json",
      "data": "/api/widget/medicines",
      "type": "application/json",
      "update": 3600,
      "screenshots": [
        {
          "src": "widget-medicines.png",
          "sizes": "256x128",
          "label": "Medicine reminder widget with refill alerts"
        }
      ],
      "icons": [
        {
          "src": "widget-icon-medicine.png",
          "sizes": "64x64",
          "type": "image/png"
        }
      ]
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://api.nabhahealth.com"
    },
    {
      "origin": "https://cdn.nabhahealth.com"
    }
  ]
}