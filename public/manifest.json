  "id": "/?source=pwa",
  "start_url": "/?source=pwa",
  "background_color": "#F9FAFB",
  "display": "standalone",
  "scope": "/",
  "theme_color": "#3B82F6",
  "orientation": "portrait-primary",
  "categories": [
    "health",
    "medical",
    "telemedicine",
    "healthcare",
    "rural",
    "india"
  ],
  "lang": "en-IN",
  "dir": "ltr",
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "shortcuts": [
    {
      "name": "Find Doctors",
      "short_name": "Doctors",
      "description": "Browse and consult with available doctors",
      "url": "/doctors?source=shortcut",
      "icons": [
        {
          "src": "shortcut-doctors.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Health Records",
      "short_name": "Records",
      "description": "View your digital health records",
      "url": "/records?source=shortcut",
      "icons": [
        {
          "src": "shortcut-records.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Symptom Checker",
      "short_name": "Symptoms",
      "description": "AI-powered symptom assessment",
      "url": "/symptoms?source=shortcut",
      "icons": [
        {
          "src": "shortcut-symptoms.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Medicine Tracker",
      "short_name": "Medicines",
      "description": "Track medicine availability and refills",
      "url": "/medicines?source=shortcut",
      "icons": [
        {
          "src": "shortcut-medicines.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Emergency",
      "short_name": "Emergency",
