{
  "name": "nabha-telemedicine",
  "version": "1.0.0",
  "private": true,
  "description": "Nabha Telemedicine Platform - Rural Healthcare Solution for SIH2025",
  "author": "SIH2025 Team",
  "license": "MIT",
  "homepage": "https://nabha-telemedicine.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/nabha-telemedicine.git"
  },
  "keywords": [
    "telemedicine",
    "rural-healthcare",
    "react",
    "pwa",
    "multilingual",
    "offline-first",
    "sih2025"
  ],
  "dependencies": {
    "lucide-react": "^0.263.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-qr-code": "^2.0.11",
    "react-router-dom": "^6.15.0",
    "react-scripts": "5.0.1",
    "react-webcam": "^7.1.1",
    "web-vitals": "^3.3.2"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "ajv": "^8.12.0",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.27",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "preview": "npm run build && serve -s build",
    "deploy": "npm run build && netlify deploy --prod --dir=build",
    "deploy:vercel": "npm run build && vercel --prod",
    "analyze": "npm run build && npx bundle-analyzer build/static/js/*.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react/prop-types": "off",
      "react/no-unescaped-entities": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "pwa": {
    "name": "Nabha Telemedicine",
    "short_name": "NabhaHealth",
    "description": "Rural Healthcare Platform",
    "theme_color": "#3B82F6",
    "background_color": "#F9FAFB",
    "display": "standalone",
    "orientation": "portrait"
  }
}
